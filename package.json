{
  "name": "@johnpwarren.dev/sprag",
  "version": "0.2.0",
  "type": "module",
  "private": false,
  "description": "Enforce human-authored architectural invariants as a ratcheted gate on every change — so AI-built codebases don't silently rot (the k10s failure mode). Real-AST (ast-grep) for Go/TS/JS/Python + a heuristic fallback; pre-commit + AI-loop + debt-trend.",
  "keywords": [
    "architecture",
    "lint",
    "ast-grep",
    "pre-commit",
    "code-quality",
    "ai-codegen",
    "technical-debt",
    "god-object"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "sprag": "arch.mjs"
  },
  "files": [
    "arch.mjs",
    "arch-gate.mjs",
    "ast-engine.mjs",
    "metrics.mjs",
    "arch-trend.mjs",
    "arch-loop.mjs",
    "scan.mjs",
    "mutate.mjs",
    "install-hook.sh",
    "library/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/johnpatrickwarren-oss/sprag.git"
  },
  "homepage": "https://github.com/johnpatrickwarren-oss/sprag#readme",
  "bugs": {
    "url": "https://github.com/johnpatrickwarren-oss/sprag/issues"
  },
  "dependencies": {
    "@ast-grep/lang-go": "^0.0.6",
    "@ast-grep/lang-python": "^0.0.6",
    "@ast-grep/napi": "^0.43.0"
  },
  "scripts": {
    "test": "node run-tests.mjs",
    "gate": "node arch-gate.mjs",
    "arch": "node arch.mjs"
  }
}
